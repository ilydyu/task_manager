# App
APP_NAME=task_manager
APP_VERSION=v0.1.1
ENV=dev
SECRET=secret

# Logger
LOGGER_PRETTY_CONSOLE=true
LOGGER_LEVEL=debug

# MYSQL
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_PORT=3306
MYSQL_HOST=localhost
MYSQL_DB_NAME=task_manager

# Redis
REDIS_ADDR=localhost:6379

# Goose 
GOOSE_DRIVER=mysql
GOOSE_DBSTRING=user:password@/task_manager?parseTime=true
GOOSE_MIGRATION_DIR=./migrations

